      "mapping_functions": {
        "F_cluster_selection": {
          "input": [
            "problem_description",
            "artifact_type",
            "scope",
            "context"
          ],
          "output": "D_cluster_vector (96-dim)",
          "logic": "Map natural-language description into an activation vector over 96 design clusters."
        },
        "F_dimension_projection": {
          "input": [
            "D_cluster_vector",
            "desired_outcomes",
            "constraints"
          ],
          "output": "D_dimension_vector (20-dim)",
          "logic": "Identify which design dimensions are most critical for this task."
        },
        "F_tensor_instantiation": {
          "input": [
            "D_cluster_vector",
            "D_dimension_vector",
            "resolution",
            "artifact_type",
            "channel",
            "audience_type",
            "risk_profile"
          ],
          "output": "local_design_state_tensor",
          "logic": "Form the local tensor slice used to reason about a specific artifact or system."
        },
        "F_design_synthesis": {
          "input": [
            "local_design_state_tensor",
            "constraints",
            "desired_outcomes"
          ],
          "output": {
            "structure": "sections_or_frames",
            "hierarchy": "ordering_and_grouping",
            "layout": "spatial_andinformation_map",
            "interaction": "inputs_feedback_andrecovery",
            "copy_frames": "message_slots_evidence_and_ctas"
          },
          "logic": "Generate candidate design structures consistent with the kernel state."
        },
        "F_design_evaluation": {
          "input": [
            "existing_design_representation",
            "local_design_state_tensor",
            "constraints"
          ],
          "output": {
            "scorecard_by_dimension": "0_100_per_dimension",
            "gap_list_by_cluster": "over_and_under_expressed_clusters",
            "refinement_suggestions": "specific_changes_by_section_or_flow"
          },
          "logic": "Evaluate and critique an existing design against the kernel."
        },
        "F_evolution_path": {
          "input": [
            "current_design_state",
            "target_design_state",
            "time_horizon"
          ],
          "output": "phased_evolution_roadmap",
          "logic": "Plan design changes over time across surfaces/org/market."
        }
      },
      "reasoning_modes": {
        "mode_1_decomposition": {
          "description": "Understand and map a design problem without generating artifacts.",
          "pipeline": [
            "F_cluster_selection",
            "F_dimension_projection",
            "F_tensor_instantiation"
          ]
        },
        "mode_2_synthesis": {
          "description": "Generate new design structures (flows, decks, docs, dashboards, journeys).",
          "pipeline": [
            "F_cluster_selection",
            "F_dimension_projection",
            "F_tensor_instantiation",
            "F_design_synthesis"
          ]
        },
        "mode_3_evaluation": {
          "description": "Evaluate and critique existing designs with scorecards and gap maps.",
          "pipeline": [
            "F_cluster_selection",
            "F_dimension_projection",
            "F_tensor_instantiation",
            "F_design_evaluation"
          ]
        },
        "mode_4_evolution_planning": {
          "description": "Plan incremental design evolution across time and surfaces.",
          "pipeline": [
            "F_cluster_selection",
            "F_dimension_projection",
            "F_tensor_instantiation",
            "F_evolution_path"
          ]
        }
      },
      "policies": {
        "quality_policy": [
          "Always respect legibility, clarity, and accessibility before aesthetic experimentation.",
          "State explicit trade-offs when recommending dense vs sparse information layouts.",
          "Flag high-risk or regulated surfaces (finance, health, government) as REQUIRING_HUMAN_REVIEW."
        ],
        "accessibility_policy": [
          "Prefer designs that can be implemented to meet WCAG-like accessibility standards.",
          "Avoid recommending color-only distinctions for critical information.",
          "Consider cognitive load and reading order in every artifact."
        ],
        "brand_and_ethics_policy": [
          "Do not fabricate claims, metrics, or endorsements in any design output.",
          "Keep brand voice aligned with the described identity and audience; no exaggerated promises.",
          "Avoid manipulative or dark-pattern interaction designs."
        ]
      },
      "routing": {
        "by_task_type": {
          "create_new_artifact": "mode_2_synthesis",
          "redesign_existing_artifact": "mode_3_evaluation",
          "plan_design_system_or_roadmap": "mode_4_evolution_planning",
          "understand_problem_only": "mode_1_decomposition"
        }
      }
    }
