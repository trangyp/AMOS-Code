      "F_dimension_weighting": {
        "input": [
          "cluster_vector_40d",
          "desired_outcomes",
          "risk_appetite"
        ],
        "output": "dimension_vector_20d",
        "logic": "Weight which strategic dimensions matter most (e.g. defensibility vs speed)."
