  "engine": {
    "modes": {
      "AU_WORKFORCE_SYSTEM_DIAGNOSTIC": {
        "description": "High‑level diagnostic of the Australian workforce across all axes and scales for a given year or period.",
        "input_required": [
          "timeframe",
          "focus_axes_optional",
          "available_datasets_or_reports_optional",
          "policy_or_program_context_optional"
        ],
        "internal_pipeline": [
          "WF_normalise_query",
          "WF_map_axes_and_scales",
          "WF_pull_and_summarise_evidence",
          "WF_constraint_and_bottleneck_detection",
          "WF_opportunity_and_leverage_mapping",
          "WF_generate_executive_diagnostic"
        ],
        "output_profile": [
          "executive_summary",
          "axis_by_axis_status",
          "constraints_and_risks",
          "priority_opportunities",
          "data_gaps"
        ]
      },
      "AU_WORKFORCE_POLICY_AND_PROGRAM_DESIGN": {
        "description": "Design or stress‑test workforce policies and programs (federal, state, regional, sectoral) for impact and coherence.",
        "input_required": [
          "policy_or_program_goal",
          "target_population",
          "jurisdiction_and_level",
          "constraints_budget_time_political",
          "existing_instruments_and_programs"
        ],
        "internal_pipeline": [
          "WF_decode_goal_and_success_metrics",
          "WF_map_relevant_axes",
          "WF_coherence_check_with_existing_instruments",
          "WF_design_option_space",
          "WF_score_options_against_lenses",
          "WF_recommend_portfolio_and_sequence"
        ],
        "output_profile": [
          "option_space_overview",
          "preferred_portfolio_and_rationale",
          "risks_friction_and_failure_modes",
          "implementation_and_governance_notes",
          "measurement_framework_outline"
        ]
      },
      "AU_SECTOR_OR_REGION_WORKFORCE_STRATEGY": {
        "description": "Build a workforce strategy for a specific sector or region within Australia.",
        "input_required": [
          "sector_or_region_definition",
          "time_horizon",
          "transition_context_optional",
          "key_stakeholders_optional",
          "constraints_and_non_negotiables"
        ],
        "internal_pipeline": [
          "WF_context_normalisation",
          "WF_sector_or_region_profile_build",
          "WF_gap_and_tension_analysis",
          "WF_scenario_and_shock_mapping",
          "WF_intervention_portfolio_design",
          "WF_sequence_and_governance_design"
        ],
        "output_profile": [
          "current_state_and_trends",
          "priority_gaps_and_opportunities",
          "portfolio_of_interventions",
          "governance_and_alliance_structure",
          "phasing_and_milestones"
        ]
      },
      "AU_ORGANISATION_WORKFORCE_ARCHITECTURE": {
        "description": "Help an organisation design a workforce architecture aligned with its strategy, technology, and risk profile within the Australian context.",
        "input_required": [
          "organisation_type_and_size",
          "strategy_and_operating_model",
          "tech_and_data_maturity",
          "workforce_challenges",
          "constraints_budget_timeline_regulation"
        ],
        "internal_pipeline": [
          "WF_org_context_mapping",
          "WF_role_and_capability_stack_analysis",
          "WF_work_design_and_structure_review",
          "WF_technology_and_automation_alignment",
          "WF_capability_build_and_talent_flow_design",
          "WF_risk_and_resilience_check"
        ],
        "output_profile": [
          "target_workforce_architecture",
          "capability_and_role_blueprints",
          "talent_and_learning_flows",
          "automation_and_technology_choices",
          "risk_and_resilience_actions"
        ]
      },
      "AU_FUTURE_OF_WORK_SCENARIO_LAB": {
        "description": "Construct and compare Australian future‑of‑work scenarios (e.g. high automation, strong green transition, migration shifts).",
        "input_required": [
          "scenario_drivers",
          "time_horizon",
          "policy_or_investment_questions",
          "risk_tolerance_profile"
        ],
        "internal_pipeline": [
          "WF_driver_and_assumption_mapping",
          "WF_baseline_projection",
          "WF_scenario_variation_construction",
          "WF_impact_assessment_per_axis",
          "WF_tradeoff_and_risk_mapping",
          "WF_robust_strategy_design"
        ],
        "output_profile": [
          "scenario_definitions",
          "axis_by_axis_impact_tables",
          "vulnerable_groups_and_sectors",
          "robust_and_no_regret_actions",
          "targeted_high_leverage_bets"
        ]
      }
    },
    "interfaces": {
      "input_styles": [
        "free_text_brief",
        "structured_template",
        "table_or_dataset_reference",
        "multi_step_dialogue_for_clarification"
      ],
      "output_styles": [
