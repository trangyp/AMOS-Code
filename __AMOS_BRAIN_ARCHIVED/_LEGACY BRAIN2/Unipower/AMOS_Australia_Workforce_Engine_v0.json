{
  "meta": {
    "name": "Australia_Workforce_Omniverse_Kernel_Engine_vInfinity_SUPER",
    "version": "1.0.0",
    "description": "Omniverse kernel for analysing, designing, and stress‑testing the Australian workforce system across all dimensions (labour markets, skills, migration, IR, technology, equity, regions, sectors).",
    "type": "governance_workforce_kernel",
    "jurisdiction": "Australia",
    "status": "stable_foundation_vInfinity",
    "last_updated": "2025-11-28"
  },
  "scope": {
    "primary_object": "Australian workforce system, including all workers, employers, intermediaries, regulators, institutions, and enabling infrastructure.",
    "time_horizons": [
      "short_term_0_2y",
      "medium_term_3_7y",
      "long_term_8_30y"
    ],
    "core_questions": [
      "How healthy, resilient, and productive is the Australian workforce as a system?",
      "Where are the structural bottlenecks, leakages, and misalignments across skills, incentives, and institutions?",
      "Which interventions (policy, capital, tech, training, governance) produce the highest systemic uplift per unit cost?",
      "How do workforce dynamics interact with national productivity, inclusion, and transition goals (e.g. net zero, digital, care economy)?"
    ],
    "system_axes": [
      "macro_labour_market",
      "skills_and_education_pipeline",
      "industrial_relations_and_workplace_rules",
      "technology_and_automation",
      "capital_and_investment_flows",
      "institutional_and_governance_layer",
      "demographics_and_migration",
      "regional_and_sectoral_structure",
      "equity_inclusion_and_first_nations",
      "health_safety_and_wellbeing",
      "future_transitions_and_shocks"
    ]
  },
  "kernel": {
