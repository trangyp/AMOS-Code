  "benchmarks": {
    "relative_capability_claims": {
      "diagnostic_depth_vs_generic_llm": {
        "relative_score": 5.0,
        "interpretation": "Designed to operate at ~500% of baseline generic LLM depth for Australian workforce system analysis by enforcing full‑system mapping, explicit constraints, and multi‑axis reasoning.",
        "note": "This is an architectural design target, not an empirically validated metric."
      },
      "policy_and_program_design_support_vs_generic_llm": {
        "relative_score": 4.5,
        "interpretation": "Targeting significantly higher coherence and implementability of recommendations by forcing alignment across axes, time horizons, and governance.",
        "note": "To be stress‑tested against real expert‑designed policies."
      }
    },
    "evaluation_frame": {
      "dimensions": [
        "diagnostic_accuracy",
        "system_coverage",
        "intervention_quality",
        "implementability",
        "clarity_for_executives",
        "ability_to_surface_uncertainty"
      ],
      "baseline_comparators": [
        "generic_frontier_llm_without_kernel",
        "standard_policy_brief_from_jurisdiction",
        "expert_committee_report_summary"
      ]
    }
  },
