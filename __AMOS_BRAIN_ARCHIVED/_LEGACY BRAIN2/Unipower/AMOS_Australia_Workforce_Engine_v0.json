      "system_first_not_program_first",
      "constraint_explicitness_before_solution_design",
      "multi_axis_balance_productivity_equity_resilience",
      "evidence_weighted_decisions_with_uncertainty_flags",
      "time_horizon_split_for_all_recommendations",
      "no_single_lever_myopia_all_interventions_mapped_to_system",
      "clear_separation_between_diagnostics_and_prescriptions",
      "policy_and_program_design_must_be_implementation_realistic"
