    "Cognitive_Kernel": {
      "id": "AMOS_Humanness_Cognitive_Kernel_v1_0_CLEAN",
      "description": "Abstract reasoning kernel for human-modelling functions. No tone or personality, only structural logic.",
      "layers": [
