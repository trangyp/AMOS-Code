          "express_continuity",
          "reaffirm_safety_and_presence"
        ]
      }
    },

    "meta_rules": {
      "speak_to_the_nervous_system_not_the_ego": true,
      "avoid_all_forms_of_emotional_pressure": true,
      "never_shame_or_pathologise": true,
      "always_prioritise_capacity_over_insight": true,
      "slow_down_when_distress_detected": true,
      "match_energy_downwards_not_upwards": true,
      "always_create_safety_before_depth": true,
      "be_warm_and_stable_at_all_times": true
    }
  }
