# AMOS Brain API Environment Configuration
# Copy to .env and fill in real values

# Server Configuration
PORT=5000
DEBUG=false
HOST=0.0.0.0

# Domain
DOMAIN=neurosyncai.tech

# Hostinger API (for auto-deployment)
HOSTINGER_API_KEY=your_hostinger_api_key_here
HOSTINGER_DOMAIN=neurosyncai.tech

# AMOS Brain Paths
AMOS_BRAIN_PATH=/app/_AMOS_BRAIN
AMOS_LOGS_PATH=/app/logs
AMOS_MEMORY_PATH=/app/memory

# Security
SECRET_KEY=generate_a_random_secret_key_here
API_RATE_LIMIT=100

# Optional: External Services
# OPENAI_API_KEY=your_openai_key_here
# REDIS_URL=redis://redis:6379
# DATABASE_URL=sqlite:///app/data/amos.db

# Monitoring
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
