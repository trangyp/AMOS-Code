# AMOS Equation System v2.0 - Environment Configuration
# Copy to .env and fill in real values
# Python 3.10+ required

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=AMOS Equation System
DEBUG=false
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_VERIFY=30
RATE_LIMIT_ADMIN=1000

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL (Production)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/amos_equations

# SQLite (Development)
# DATABASE_URL=sqlite+aiosqlite:///./amos_equations.db

DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# REDIS / CACHE
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CACHE_TTL=3600
CACHE_ENABLED=true

# =============================================================================
# CELERY / BACKGROUND TASKS
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_ALWAYS_EAGER=false

# =============================================================================
# OBSERVABILITY
# =============================================================================
# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=amos-equation-system
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Prometheus
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_FLAGS_BACKEND=file
FEATURE_FLAGS_FILE=./feature_flags.json
# FEATURE_FLAGS_BACKEND=redis

# =============================================================================
# DATA I/O
# =============================================================================
EXPORT_MAX_ROWS=100000
EXPORT_CHUNK_SIZE=1000
EXPORT_STORAGE_PATH=./exports
EXPORT_S3_BUCKET=
EXPORT_EMAIL_ENABLED=false

IMPORT_MAX_FILE_SIZE=104857600
IMPORT_CHUNK_SIZE=1000
IMPORT_BATCH_SIZE=500

# =============================================================================
# WEBHOOK (Optional)
# =============================================================================
WEBHOOK_SECRET=webhook-signing-secret
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT_SECONDS=30

# =============================================================================
# EMAIL (Optional - for notifications)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
FROM_EMAIL=noreply@example.com

# =============================================================================
# DEVELOPMENT / TESTING
# =============================================================================
SEEDER_DEFAULT_LOCALE=en_US
SEEDER_BATCH_SIZE=100
SEEDER_CLEAR_BEFORE_SEED=false

# Test Database (isolated from main)
TEST_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/amos_equations_test

# =============================================================================
# LLM PROVIDER API KEYS (Required for SuperBrain 100% health)
# =============================================================================
# At least one provider required for AI capabilities
# Get keys from: OpenAI (platform.openai.com), Anthropic (console.anthropic.com)
# Kimi (platform.moonshot.cn), Ollama (local installation)

# OpenAI - GPT-4, GPT-4o, GPT-3.5
# OPENAI_API_KEY=sk-...

# Anthropic - Claude 3.5 Sonnet, Claude 3 Opus
# ANTHROPIC_API_KEY=sk-ant-...

# Kimi (Moonshot AI) - Kimi K2.5
# KIMI_API_KEY=...

# Ollama (Local models) - No API key needed for local instance
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# THIRD-PARTY INTEGRATIONS (Optional)
# =============================================================================
# Sentry (for error tracking)
# SENTRY_DSN=https://...

# AWS (for S3 exports)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
