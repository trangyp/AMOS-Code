# AMOS Backend - Environment Configuration
#
# Copy this file to .env and fill in your values.
# Never commit .env files to version control!
#
# Creator: Trang Phan
# Version: 3.0.0

# ============================================
# Server Configuration
# ============================================

# Host to bind the server (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# Port to run the server on
API_PORT=8000

# Number of worker processes (set to 1 for development)
API_WORKERS=1

# ============================================
# CORS Configuration
# ============================================

# Allowed origins for CORS (JSON array)
# For development, include your frontend URL
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ============================================
# Security
# ============================================

# Secret key for session management and encryption
# Generate a strong random string for production
SECRET_KEY=your-super-secret-key-change-in-production

# ============================================
# Optional: Database (for persistent storage)
# ============================================

# PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/amos

# SQLite (simple file-based, for development)
# SQLITE_URL=sqlite:///./amos.db

# ============================================
# Optional: Redis (for caching)
# ============================================

# Redis connection string
# REDIS_URL=redis://localhost:6379/0

# ============================================
# Optional: External Services
# ============================================

# OpenAI API Key (if using OpenAI features)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (if using Claude features)
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# Logging
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log format (json, text)
LOG_FORMAT=text
