              "rw_antil_invol",
              "rw_nlogic_on_atom",
              "rw_implies"
            ],
            "parameters": {
              "max_normalize_iters": 128,
              "max_backward_depth": 16
            },
            "guarantees": [
              "finite_rewrite_sequence_or_safe_cutoff",
              "paradox_and_bottom_mark_true_contradiction",
