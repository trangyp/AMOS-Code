{
  " AMOS Tool Lattice - Duplicate Detection Configuration": "jscpd",
  "docs": "https://jscpd.dev/",
  "purpose": "Detect code duplication across the AMOS codebase",
  "kernel": "Repo-Enforcement Kernel",
  
  "threshold": 5,
  "reporters": ["html", "console", "json"],
  "output": "./reports/jscpd",
  "ignore": [
    "**/tests/**",
    "**/test_*.py",
    "**/__pycache__/**",
    "**/*.pyc",
    "**/venv/**",
    "**/.venv/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/docs/**",
    "**/*.md",
    "**/*.json",
    "**/*.yaml",
    "**/*.yml",
    "**/generated/**",
    "**/AMOS_ORGANISM_OS/**",
    "**/_AMOS_BRAIN/**",
    "**/_00_AMOS_CANON/**"
  ],
  "formats": ["python"],
  "blame": false,
  "silent": false,
  "absolute": false,
  "minLines": 5,
  "minTokens": 50,
  "maxLines": 500,
  "maxSize": "50mb",
  "maxFileSize": "5mb",
  "mode": "mild",
  "failOnErrors": false
}
