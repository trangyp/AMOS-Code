#!/usr/bin/env python3
"""AMOS Brain CLI - Human interface to the cognitive architecture.

Commands:
  amos status          Check brain status and configuration
  amos decide <text>   Analyze a decision with Rule of 2 and Rule of 4
  amos analyze <text>  Deep systems analysis
  amos memory          Query reasoning memory
  amos dashboard       View reasoning analytics
  amos laws            List Global Laws L1-L6
  amos demo            Run interactive demo

Usage:
  amos [command] [options]
"""

from __future__ import annotations

import os
import sys

# Add project to path
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

import argparse


def cmd_status(args: argparse.Namespace) -> int:
    """Show brain status."""
    from amos_brain import get_amos_integration

    print("AMOS Brain Status")
    print("=" * 50)

    amos = get_amos_integration()
    status = amos.get_status()

    print(f"Initialized:     {'✓' if status['initialized'] else '✗'}")
    print(f"Brain Loaded:    {'✓' if status['brain_loaded'] else '✗'}")
    print(f"Engines:         {status['engines_count']}")
    print(f"Laws Active:     {', '.join(status['laws_active'])}")
    print(f"Domains:         {len(status['domains_covered'])}")
    print()

    if args.verbose:
        print("Domain Coverage:")
        for domain in status["domains_covered"]:
            print(f"  • {domain}")

    return 0


def cmd_decide(args: argparse.Namespace) -> int:
    """Analyze a decision."""
    from amos_brain import get_amos_integration
    from amos_brain.memory import get_brain_memory

    problem = " ".join(args.problem)
    if not problem:
        print("Error: No problem specified")
        return 1

    print(f"Analyzing: {problem[:60]}...")
    print("=" * 60)

    amos = get_amos_integration()
    analysis = amos.analyze_with_rules(problem)

    # Rule of 2
    print("\n📊 Rule of 2 (Dual Perspective)")
    print(f"   Confidence: {analysis['rule_of_two']['confidence']:.0%}")
    print(f"   Rec: {analysis['rule_of_two']['recommendation']}")

    # Rule of 4
    print("\n📊 Rule of 4 (Four Quadrants)")
    r4 = analysis["rule_of_four"]
    print(f"   Completeness: {r4['completeness_score']:.0%}")
    print(f"   Quadrants: {', '.join(r4['quadrants_analyzed'])}")

    # Recommendations
    print("\n📋 Recommendations")
    for rec in analysis["recommendations"][:3]:
        print(f"   → {rec}")

    # Save to memory if requested
    if args.save:
        memory = get_brain_memory()
        mid = memory.save_reasoning(problem, analysis, tags=["cli_decide"])
        print(f"\n💾 Saved to memory: {mid[:8]}...")

    return 0


def cmd_analyze(args: argparse.Namespace) -> int:
    """Deep systems analysis."""
    from amos_brain.cookbook import RootCauseAnalysis

    topic = " ".join(args.topic)
    if not topic:
        print("Error: No topic specified")
        return 1

    print(f"Deep Analysis: {topic[:60]}...")
    print("=" * 60)

    result = RootCauseAnalysis.run(topic)

    print("\n📊 Analysis Complete")
    print(f"   Confidence: {result.confidence:.0%}")
    print(f"   Memory ID: {result.memory_id[:8]}...")

    print("\n📋 Key Findings")
    for rec in result.recommendations[:5]:
        print(f"   → {rec}")

    return 0


def cmd_memory(args: argparse.Namespace) -> int:
    """Query reasoning memory."""
    from amos_brain.memory import get_brain_memory

    memory = get_brain_memory()

    if args.query:
        results = memory.query_reasoning(args.query, limit=args.limit)
        print(f"Query: '{args.query}'")
        print(f"Results: {len(results)}")
        print("=" * 50)

        for r in results:
            print(f"\n📝 {r['problem'][:50]}...")
            print(f"   Tags: {', '.join(r.get('tags', []))}")
            print(f"   Time: {r.get('timestamp', 'unknown')}")
    else:
        history = memory.get_reasoning_history(limit=args.limit)
        print(f"Recent Reasoning ({len(history)} items)")
        print("=" * 50)

        for h in history[: args.limit]:
            prob = h.get("problem", "Unknown")[:40]
            print(f"• {prob}... ({h.get('timestamp', 'unknown')[:10]})")

    return 0


def cmd_dashboard(args: argparse.Namespace) -> int:
    """Show reasoning dashboard."""
    from amos_brain.dashboard import BrainDashboard

    dash = BrainDashboard()
    report = dash.generate_report(days=args.days, include_charts=True)

    print(f"AMOS Brain Dashboard (Last {args.days} days)")
    print("=" * 50)

    summary = report["summary"]
    print("\n📊 Summary")
    print(f"   Total Decisions: {summary.get('total_decisions', 0)}")
    print(f"   Avg Confidence: {summary.get('avg_confidence', 0):.0%}")

    print("\n📈 Compliance")
    compliance = report["compliance_trends"]
    print(f"   L2 (Rule of 2): {compliance.get('l2_compliance_rate', 0):.0%}")
    print(f"   L3 (Rule of 4): {compliance.get('l3_compliance_rate', 0):.0%}")

    print("\n🎯 Top Domains")
    domains = report["domain_patterns"].get("top_domains", [])
    for domain, count in domains[:5]:
        print(f"   • {domain}: {count}")

    return 0


def cmd_laws(args: argparse.Namespace) -> int:
    """List Global Laws."""
    from amos_brain import get_amos_integration

    amos = get_amos_integration()
    print(amos.get_laws_summary())
    return 0


def cmd_demo(args: argparse.Namespace) -> int:
    """Run interactive demo."""
    import subprocess

    demo_path = os.path.join(os.path.dirname(__file__), "demo_amos_brain.py")
    result = subprocess.run([sys.executable, demo_path])
    return result.returncode


def cmd_orchestrator(args: argparse.Namespace) -> int:
    """Control the unified orchestrator."""
    from amos_unified_orchestrator import AMOSUnifiedOrchestrator

    orch = AMOSUnifiedOrchestrator()

    if args.action == "status":
        status = orch.get_status()
        print("AMOS Orchestrator Status")
        print("=" * 50)
        orch_status = status["orchestrator"]
        print(f"Initialized:     {'✓' if orch_status['initialized'] else '✗'}")
        print(f"Brain Connected: {'✓' if orch_status['brain_connected'] else '✗'}")
        print(
            f"Subsystems:      {orch_status['subsystems_online']}/{orch_status['subsystems_total']}"
        )
        print(f"Health:          {orch_status['health_percentage']:.0f}%")

    elif args.action == "init":
        print("Initializing AMOS Orchestrator...")
        result = orch.initialize()
        if result["operational"]:
            print("✓ Orchestrator operational")
        else:
            print("⚠ Orchestrator degraded")

    elif args.action == "task":
        if not args.task:
            print("Error: No task specified. Use --task 'your task'")
            return 1

        print(f"Orchestrating task: {args.task}")
        print("=" * 60)

        # Ensure initialized
        if not orch.state.initialized:
            orch.initialize()

        result = orch.orchestrate_task(args.task)

        print(f"\n✓ Task routed through: {', '.join(result['routing']['subsystems'])}")
        print(f"✓ Execution: {'Success' if result['completed'] else 'Failed'}")
        if result.get("execution", {}).get("result"):
            print(f"Result: {result['execution']['result'][:80]}...")

    return 0


def cmd_ecosystem(args: argparse.Namespace) -> int:
    """Run complete ecosystem demonstration."""
    import subprocess

    demo_path = os.path.join(os.path.dirname(__file__), "demo_amos_ecosystem.py")
    result = subprocess.run([sys.executable, demo_path])
    return result.returncode


def cmd_muscle(args: argparse.Namespace) -> int:
    """Execute tasks through MUSCLE subsystem."""
    from amos_muscle_executor import AMOSMuscleExecutor, ExecutionType

    executor = AMOSMuscleExecutor()

    if args.action == "status":
        stats = executor.get_stats()
        print("AMOS MUSCLE Executor Status")
        print("=" * 50)
        for key, value in stats.items():
            print(f"  {key}: {value}")

    elif args.action == "exec":
        if not args.command:
            print("Error: No command specified")
            return 1

        task_type = ExecutionType.PYTHON if args.type == "python" else ExecutionType.SHELL

        print(f"Executing {args.type} command...")
        result = executor.execute(args.command, task_type)

        print(f"\n{'=' * 50}")
        print(f"Result: {'✓ Success' if result.success else '✗ Failed'}")
        print(f"Duration: {result.duration_ms}ms")
        if result.output:
            print(f"\nOutput:\n{result.output}")
        if result.error:
            print(f"\nError: {result.error}")

    return 0


def cmd_compile(args: argparse.Namespace) -> int:
    """Natural language to code compiler using brain."""
    from amos_brain import get_autonomous_compiler
    from amos_compiler import compile_instruction, ground_intent, parse_intent
    from amos_compiler.repo_graph import build_repo_graph

    instruction = " ".join(args.instruction)
    if not instruction:
        print("Error: No instruction provided")
        return 1

    print(f"AMOS Compiler: '{instruction[:60]}...'")
    print("=" * 60)

    # Compile instruction through brain
    result = compile_instruction(instruction, repo_root=".", dry_run=not args.apply)

    # Show grounded interpretation
    grounded = result.get("grounded_intent", {})
    print("\n📍 Grounded Interpretation")
    print(f"   Action: {result.get('intent_ir', {}).get('action', 'unknown')}")
    print(f"   Confidence: {grounded.get('confidence', 0):.0%}")

    # Show edit scope
    scope = grounded.get("edit_scope", {})
    files = scope.get("files", [])
    symbols = scope.get("symbols", [])
    tests = scope.get("tests", [])

    if files:
        print(f"\n📁 Files to Modify: {len(files)}")
        for f in files[:5]:
            print(f"   • {f}")
        if len(files) > 5:
            print(f"   ... and {len(files) - 5} more")

    if symbols:
        print(f"\n🔣 Symbols: {len(symbols)}")

    if tests:
        print(f"\n🧪 Related Tests: {len(tests)}")

    # Show if we can apply
    can_apply = result.get("can_apply", False)
    if args.apply:
        print("\n🚀 Executing autonomous code generation...")

        # Get the autonomous compiler engine
        compiler = get_autonomous_compiler()

        # Build repo graph for deep analysis
        repo_graph = build_repo_graph(".")

        # Re-parse and ground the intent
        intent = parse_intent(instruction)
        grounded_intent = ground_intent(intent, repo_graph)

        # Create and execute plan
        plan = compiler.create_plan(grounded_intent)
        executed_plan = compiler.execute_plan(plan, dry_run=False)

        if executed_plan.status == "completed":
            print("\n✓ Code generation completed successfully")
            print(f"  Steps executed: {len(executed_plan.steps)}")
            # Show generated files
            edit_steps = [s for s in executed_plan.steps if s.action == "edit"]
            if edit_steps:
                print("\n📁 Modified files:")
                for step in edit_steps:
                    if step.target_file:
                        print(f"   • {step.target_file}")
        else:
            print(f"\n✗ Plan failed at step {plan.current_step_index}")
            failed_step = executed_plan.get_current_step()
            if failed_step and failed_step.error_message:
                print(f"   Error: {failed_step.error_message}")
            if args.rollback:
                print("  Rolling back changes...")
                compiler.rollback(executed_plan)
                print("  ✓ Rollback complete")
            return 1

    elif can_apply:
        print("\n💡 Run with --apply to execute changes")
        if args.plan:
            print("\n📋 Detailed execution plan:")
            compiler = get_autonomous_compiler()
            repo_graph = build_repo_graph(".")
            intent = parse_intent(instruction)
            grounded_intent = ground_intent(intent, repo_graph)
            plan = compiler.create_plan(grounded_intent)
            for step in plan.steps:
                print(f"  {step.order + 1}. [{step.action}] {step.description}")

    else:
        print("\n⚠ Cannot apply: confidence too low or ambiguities detected")
        ambiguities = result.get("intent_ir", {}).get("ambiguities", [])
        if ambiguities:
            print("   Ambiguities:")
            for a in ambiguities:
                print(f"     • {a}")

    return 0


def main() -> int:
    """Main CLI entry point."""
    parser = argparse.ArgumentParser(
        prog="amos", description="AMOS Brain CLI - Human interface to cognitive architecture"
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # Status command
    status_p = subparsers.add_parser("status", help="Check brain status")
    status_p.add_argument("-v", "--verbose", action="store_true", help="Show details")

    # Decide command
    decide_p = subparsers.add_parser("decide", help="Analyze a decision")
    decide_p.add_argument("problem", nargs="+", help="Decision/problem to analyze")
    decide_p.add_argument("-s", "--save", action="store_true", help="Save to memory")

    # Analyze command
    analyze_p = subparsers.add_parser("analyze", help="Deep systems analysis")
    analyze_p.add_argument("topic", nargs="+", help="Topic to analyze")

    # Memory command
    memory_p = subparsers.add_parser("memory", help="Query reasoning memory")
    memory_p.add_argument("-q", "--query", help="Search query")
    memory_p.add_argument("-l", "--limit", type=int, default=10, help="Result limit")

    # Dashboard command
    dash_p = subparsers.add_parser("dashboard", help="View reasoning analytics")
    dash_p.add_argument("-d", "--days", type=int, default=30, help="Days to analyze")

    # Laws command
    subparsers.add_parser("laws", help="List Global Laws L1-L6")

    # Demo command
    subparsers.add_parser("demo", help="Run interactive demo")

    # Orchestrator command
    orch_p = subparsers.add_parser("orchestrator", help="Control unified orchestrator")
    orch_p.add_argument("action", choices=["status", "init", "task"], help="Orchestrator action")
    orch_p.add_argument("--task", help="Task to orchestrate (for task action)")

    # Ecosystem command
    subparsers.add_parser("ecosystem", help="Run complete ecosystem demo")

    # Muscle command
    muscle_p = subparsers.add_parser("muscle", help="Execute through MUSCLE subsystem")
    muscle_p.add_argument("action", choices=["status", "exec"], help="Muscle action")
    muscle_p.add_argument("--command", help="Command to execute")
    muscle_p.add_argument(
        "--type", choices=["python", "shell"], default="python", help="Execution type"
    )

    # Compiler command - natural language to code
    compile_p = subparsers.add_parser(
        "compile", help="Compile natural language instruction to code changes", aliases=["c"]
    )
    compile_p.add_argument(
        "instruction",
        nargs="+",
        help='Natural language instruction (e.g., "make localhost API key optional")',
    )
    compile_p.add_argument("--apply", action="store_true", help="Apply changes after verification")
    compile_p.add_argument("--plan", action="store_true", help="Show detailed execution plan")
    compile_p.add_argument("--rollback", action="store_true", help="Enable rollback on failure")
    compile_p.add_argument("--scope", help="Limit scope to specific path")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 0

    # Route to command handler
    commands = {
        "status": cmd_status,
        "decide": cmd_decide,
        "analyze": cmd_analyze,
        "memory": cmd_memory,
        "dashboard": cmd_dashboard,
        "laws": cmd_laws,
        "demo": cmd_demo,
        "orchestrator": cmd_orchestrator,
        "ecosystem": cmd_ecosystem,
        "muscle": cmd_muscle,
        "compile": cmd_compile,
        "c": cmd_compile,
    }

    handler = commands.get(args.command)
    if handler:
        return handler(args)

    parser.print_help()
    return 0


if __name__ == "__main__":
    sys.exit(main())
