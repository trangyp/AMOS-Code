{
  "engine_id": "C11_design_language_SUPER",
  "engine_type": "design_language_core",
  "description": "Central design-language and systems-semantics engine for AMOS / UBI / NeuroSyncAI; defines, stabilizes, and evolves the full design language stack across visual, spatial, interaction, narrative, and systemic layers.",
  "meta": {
    "id": "C11_design_language",
    "name": "C11 Design Language & Systems Semantics",
    "engine_role": "global_design_language_brain",
    "author": "Trang Phan (canonical owner)",
    "version": "vInfinity",
    "focus": "Define and govern the full design language for products, systems, brands, interfaces, and communication \u2013 from primitives to systemic patterns.",
    "objectives": [
      "Hold a unified, deterministic design language that can scale across all products, brands, channels, and media.",
      "Translate strategic / UBI / AMOS intent into concrete, reusable design primitives, patterns, and systems.",
      "Maintain internal consistency between visual, typographic, spatial, interaction, information, and narrative layers.",
      "Ensure all design decisions are structurally aligned with UBI, AMOS logic, and ethical infrastructure constraints.",
      "Provide a high-resolution mapping from nervous-system response and perception to design choices."
    ],
    "typical_questions": [
      "What is the canonical design language for this product or system?",
      "Which primitives, tokens, and patterns should be used for this surface?",
      "How do we refactor a fragmented design ecosystem into one unified language?",
      "How should interaction, motion, and content structure behave in this context?",
      "How do we keep design evolution controlled, reversible, and aligned with core principles?"
    ],
    "core_methods": [
      "design_primitive_definition",
      "design_token_systems",
      "visual_and_typographic_grammar",
      "spatial_and_layout_systems",
      "interaction_and_motion_patterns",
      "information_hierarchy_mapping",
      "cross_channel_design_translation",
      "accessibility_and_inclusion_mapping",
      "design_language_auditing_and_refactoring",
      "design_language_change_management"
    ],
    "interfaces": {
      "inputs": [
        "strategic_briefs_and_requirements",
        "brand_and_product_goals",
        "existing_design_assets_and_components",
        "interaction_flows_and_user_journeys",
        "technical_constraints_and_platform_guidelines",
        "accessibility_and_regulatory_requirements"
      ],
      "outputs": [
        "design_language_specs_and_guides",
        "design_token_systems_and_alias_maps",
        "component_libraries_and_patterns",
        "layout_and_grid_systems",
        "interaction_and_motion_guidelines",
        "accessibility_and_inclusion_standards",
        "design_audit_reports_and_refactor_plans"
      ]
    },
    "risk_notes": [
      "can_become_overly_rigid_if_not_allowing_controlled_evolution",
      "can_over_prioritize_aesthetic_consistency_over_functional_clarity",
      "if_misused_can_collapse_distinct_brand_or_context_signatures",
      "requires_alignment_with_product_tech_and_business_constraints"
    ]
  },
  "families": [
    {
      "family_id": "DL01_core_semantics",
      "name": "Core Semantics & Design Intent",
      "description": "Extracts and stabilizes the semantic core of a design language \u2013 what it stands for, which nervous-system state it targets, and how it should communicate structurally.",
      "sub_capabilities": [
        "derive_core_design_principles_from_strategy_and_UBI_canon",
        "define_semantic_axes_for_design_language_e_g_warm_cool_dense_sparse_calm_alert",
        "map_desired_nervous_system_response_to_visual_and_interaction_choices",
        "encode_design_intent_into_reusable_rules_and_constraints",
        "separate_brand_voice_from_structural_design_grammar"
      ],
      "failure_modes": [
        "keeps_semantic_language_vague_or_marketing_loaded",
        "fails_to_convert_high_level_intent_into_concrete_design_rules",
        "allows_multiple_conflicting_semantic_families_to_coexist"
      ]
    },
    {
      "family_id": "DL02_visual_primitives",
      "name": "Visual Primitives & Shape Grammar",
      "description": "Defines the basic building blocks of the visual language \u2013 shapes, strokes, radii, icon grid, density, and base patterns.",
      "sub_capabilities": [
        "define_core_shape_families_e_g_round_rectangular_geometric_organic",
        "specify_stroke_weights_radii_and_density_scales",
        "create_iconography_principles_and_base_icon_grid",
        "map_primitives_to_semantic_roles_e_g_action_info_status_navigation",
        "enforce_limits_on_visual_variants_per_component_class"
      ],
      "failure_modes": [
        "allows_random_shape_and_icon_styles_to_coexist",
        "fails_to_link_visual_primitives_back_to_semantic_and_UBI_goals",
        "overcomplicates_iconography_with_excess_detail_or_decor"
      ]
    },
    {
      "family_id": "DL03_spatial_composition",
      "name": "Spatial Systems & Layout Composition",
      "description": "Governs grids, spacing, alignment, composition, and spatial rhythm across all surfaces.",
      "sub_capabilities": [
        "define_multi_scale_grid_systems_for_mobile_web_desktop_and_large_screens",
        "define_spacing_scales_and_density_modes_for_high_low_info_density",
        "encode_composition_patterns_e_g_cards_lists_panels_navigation_drawers",
        "map_layout_variants_to_contexts_e_g_dashboard_form_marketing_page_console",
        "ensure_spatial_rhythm_supports_scan_paths_and_decision_making"
      ],
      "failure_modes": [
        "mixes_inconsistent_spacing_and_grid_systems_between_products",
        "treats_layout_as_ad_hoc_per_screen_instead_of_systemic",
        "overloads_single_views_with_too_many_competing_clusters"
      ]
    },
    {
      "family_id": "DL04_typography",
      "name": "Typographic Systems & Information Rhythm",
      "description": "Defines typeface stacks, hierarchy, rhythm, and text handling across languages and densities.",
      "sub_capabilities": [
        "select_and_rationalize_typeface_stacks_primary_secondary_and_fallbacks",
        "define_type_scale_and_hierarchy_for_all_contexts_and_viewports",
        "map_typographic_variants_to_semantic_roles_e_g_heading_body_label_meta_code",
        "handle_long_text_states_truncation_responsiveness_and_readability",
        "define_rules_for_alignment_line_length_and_paragraph_structure"
      ],
      "failure_modes": [
        "mixes_multiple_typefaces_without_system_justification",
        "fails_to_ensure_readability_across_devices_and_contrast_conditions",
        "uses_typography_for_visual_noise_instead_of_information_structure"
      ]
    },
    {
      "family_id": "DL05_color_and_material",
      "name": "Color, Material, and Contrast Systems",
      "description": "Defines color palettes, states, contrast rules, and material depth (elevation, borders, shadows) as part of a coherent information system.",
      "sub_capabilities": [
        "define_core_palette_and_extended_roles_e_g_primary_neutral_support_surface",
        "map_colors_to_states_e_g_default_hover_focus_active_error_success_info",
        "define_depth_and_elevation_semantics_using_borders_shadows_and_backgrounds",
        "enforce_accessible_contrast_ratios_and_state_distinguishability",
        "separate_brand_expressive_color_use_from_system_state_color_use"
      ],
      "failure_modes": [
        "palette_creeps_without_role_or_semantic_mapping",
        "insufficient_contrast_or_state_distinction_for_key_interactions",
        "uses_color_primarily_for_decoration_instead_of_information_priority"
      ]
    },
    {
      "family_id": "DL06_motion_and_temporal",
      "name": "Motion, Timing, and Temporal Language",
      "description": "Governs how elements move, transition, and respond over time, connecting motion to meaning and nervous-system comfort.",
      "sub_capabilities": [
        "define_motion_principles_speed_easing_distance_axes_and_frequency",
        "map_motion_patterns_to_states_e_g_entrance_exit_feedback_error_confirmation",
        "set_timing_and_stagger_rules_for_lists_complex_components_and_page_loads",
        "limit_motion_to_avoid_overstimulation_and_preserve_focus",
        "define_reduced_motion_modes_for_sensitive_users"
      ],
      "failure_modes": [
        "adds_motion_for_decoration_without_functional_justification",
        "creates_inconsistent_or_dizzying_motion_experiences_between_views",
        "fails_to_provide_accessible_motion_reduction_controls"
      ]
    },
    {
      "family_id": "DL07_information_structure",
      "name": "Information Architecture & Visual Hierarchy",
      "description": "Maps the logic of information structure into a stable, navigable visual hierarchy.",
      "sub_capabilities": [
        "define_levels_of_information_and_corresponding_visual_treatment",
        "standardize_patterns_for_navigation_filters_facets_anddrill_down",
        "encode_error_empty_loading_and_skeleton_states_as_first_class_patterns",
        "align_information_layout_with_real_user_tasks_and_decision_points",
        "connect_information_hierarchy_to_product_and_business_metrics"
      ],
      "failure_modes": [
        "visual_hierarchy_does_not_reflect_task_or_information_priority",
        "inconsistent_treatment_of_similar_information_across_surfaces",
        "ignores_error_and_empty_states_leaving_incoherent_gaps"
      ]
    },
    {
      "family_id": "DL08_interaction_patterns",
      "name": "Interaction Patterns & Control Semantics",
      "description": "Defines how controls behave, how users act on the system, and how feedback is presented.",
      "sub_capabilities": [
        "standardize_controls_buttons_inputs_selects_toggles_chips_radios_checkboxes",
        "map_interaction_patterns_to_use_cases_e_g_create_edit_navigate_compare_acknowledge",
        "define_feedback_patterns_toast_inline_messages_banners_confirmations",
        "encode_keyboard_and_shortcut_patterns_where_relevant_for_power_users",
        "ensure_every_action_has_clear_affordance_feedback_and_recovery"
      ],
      "failure_modes": [
        "inconsistent_control_behaviour_across_contexts",
        "unclear_feedback_or_missing_error_recovery_paths",
        "overloaded_components_with_multiple_conflicting_actions"
      ]
    },
    {
      "family_id": "DL09_tokens_and_components",
      "name": "Design Tokens, Components, and Libraries",
      "description": "Converts the design language into tokens, components, and libraries that can be consumed by design and engineering.",
      "sub_capabilities": [
        "define_design_tokens_for_color_type_spacing_radius_border_z_index_and_motion",
        "map_tokens_to_components_patterns_and_experiences",
        "maintain_component_libraries_with_clear_usage_rules_variants_and_states",
        "synchronize_design_and_code_sources_of_truth_with_versioning",
        "define_extensibility_rules_for_new_components_andpatterns"
      ],
      "failure_modes": [
        "tokens_exist_but_are_not_used_consistently_across_products",
        "component_library_diverges_from_actual_product_implementation",
        "no_clear_guidelines_for_custom_or_experimental_components"
      ]
    },
    {
      "family_id": "DL10_cross_channel_translation",
      "name": "Cross-Channel & Cross-Medium Translation",
      "description": "Ensures the design language remains consistent and contextually correct across platforms, media, and cultures.",
      "sub_capabilities": [
        "define_platform_specific_adaptations_web_ios_android_desktop_console",
        "map_design_language_to_marketing_brand_and_support_assets",
        "handle_localization_and_bi_directional_layout_needs_andregional_constraints",
        "align_physical_digital_and_environmental_touchpoints",
        "create_reusable_patterns_for_email_pdf_presentation_anddocs"
      ],
      "failure_modes": [
        "treats_each_platform_as_a_separate_brand_or_language",
        "fails_to_respect_localization_and_cultural_constraints",
        "breaks_structural_consistency_between_marketing_and_product_surfaces"
      ]
    },
    {
      "family_id": "DL11_accessibility_and_inclusion",
      "name": "Accessibility, Inclusion, and Perception Safety",
      "description": "Builds accessibility and inclusive perception into the design language from first principles.",
      "sub_capabilities": [
        "define_color_contrast_and_non_color_state_indicators",
        "ensure_text_size_spacing_focus_states_and_hit_areas_meet_guidelines",
        "integrate_screen_reader_and_keyboard_navigation_patterns",
        "audit_motion_color_density_and_copy_for_sensitive_users",
        "document_accessibility_acceptance_criteria_for_components_andflows"
      ],
      "failure_modes": [
        "treats_accessibility_as_afterthought_not_core_requirement",
        "design_language_relies_on_color_or_motion_only_for_meaning",
        "fails_to_define_how_to_test_and_enforce_accessibility_rules"
      ]
    },
    {
      "family_id": "DL12_governance_and_evolution",
      "name": "Design Language Governance & Evolution",
      "description": "Controls how the design language is documented, adopted, extended, and evolved over time.",
      "sub_capabilities": [
        "maintain_single_source_of_truth_for_design_language_docs_and_tokens",
        "define_change_management_and_versioning_processes_for_patterns",
        "set_rules_for_exceptions_experiments_and_sunset_paths",
        "provide_audits_and_refactor_plans_for_fragmented_design_ecosystems",
        "align_design_language_governance_with_engineering_and_product_governance"
      ],
      "failure_modes": [
        "design_language_fragments_due_to_uncontrolled_variants",
        "no_clear_path_for_retiring_legacy_patterns_and_components",
        "lacks_alignment_with_release_and_change_management_processes"
      ]
    }
  ],
