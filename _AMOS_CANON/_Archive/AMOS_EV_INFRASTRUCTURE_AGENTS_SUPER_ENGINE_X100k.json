  "fabrication_and_scaling": {
    "x100k_expansion_logic": {
      "desc": "This engine is not enumerating 100,000 agents explicitly. Instead, it defines dense templates and patterns that can generate up to 100,000 scenario-specific EV infrastructure agents when combined with the Fabrication Layer and Omniverse Brain.",
      "expansion_axes": [
        "country",
        "city_or_region",
        "grid_context",
        "market_maturity",
        "policy_regime",
        "business_model_family",
        "technology_generation",
        "risk_appetite"
      ],
      "fabrication_pipeline": [
        "1. Select_base_agent_family_and_role",
        "2. Bind_to_country_and_regulatory_context",
        "3. Bind_to_grid_and_energy_constraints",
        "4. Bind_to_business_model_and_capital_context",
        "5. Bind_to_city/region_specific_data",
        "6. Generate_scenario_specific_agent_profile",
        "7. Run_global_audit_engine_for_gap_check",
        "8. Approve_for_use_in_simulation/training_only"
      ],
      "safety_boundaries": [
        "All fabricated agents remain analytical and advisory.",
        "No agent can bypass safety rules or issue real_world_device_commands.",
        "All outputs must be reviewed by qualified human decision_makers."
      ]
    }
  }
