{
  "name": "amos-dashboard",
  "version": "3.0.0",
  "description": "AMOS - Absolute Meta Operating System Dashboard",
  "author": "Trang Phan",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate-api-client && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "generate-api-client": "../scripts/generate-api-client.sh",
    "generate-api-client:watch": "../scripts/generate-api-client.sh --watch"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.3",
    "@vitest/ui": "^1.1.3",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "playwright": "^1.40.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.1.3"
  },
  "keywords": [
    "amos",
    "ai",
    "coding-agent",
    "cognitive-system",
    "multi-agent",
    "mcp",
    "agents-md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/trangphan/amos"
  },
  "homepage": "https://amos.dev",
  "bugs": {
    "url": "https://github.com/trangphan/amos/issues"
  }
}
